meta {
  name: Deprecated /v1/claude/models Endpoint
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/v1/claude/models
}

headers {
  Authorization: Bearer {{apiToken}}
}

tests {
  const status = res.getStatus();
  expect(status).to.equal(200);

  const body = res.getBody();
  expect(body.data).to.be.an('array');

  // Should have Deprecation header (checked via response headers in collection settings)
  expect(body.data[0]).to.have.property('id');
}
