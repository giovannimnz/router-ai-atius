meta {
  name: List Models - Anthropic Format
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/v1/models?api_format=anthropic
}

headers {
  Authorization: Bearer {{apiToken}}
}

tests {
  const status = res.getStatus();
  expect(status).to.equal(200);

  const body = res.getBody();
  expect(body.data).to.be.an('array');
  expect(body.data.length).to.be.above(0);

  // Anthropic format check
  expect(body.has_more).to.equal(false);
  expect(body.data[0]).to.have.property('id');
  expect(body.data[0]).to.have.property('type', 'model');
  expect(body.data[0]).to.have.property('created_at');
  expect(body.data[0]).to.have.property('display_name');
  expect(body.data[0]).to.have.property('api_format', 'anthropic');

  // Should have pricing info
  expect(body.data[0]).to.have.property('context_length');
  expect(body.data[0]).to.have.property('input_price');
  expect(body.data[0]).to.have.property('output_price');
}
