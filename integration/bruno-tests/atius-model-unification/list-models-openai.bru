meta {
  name: List Models - OpenAI Format
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/v1/models
}

headers {
  Authorization: Bearer {{apiToken}}
}

tests {
  const status = res.getStatus();
  expect(status).to.equal(200);

  const body = res.getBody();
  expect(body.data).to.be.an('array');
  expect(body.data.length).to.be.above(0);

  // OpenAI format check
  expect(body.object).to.equal('list');
  expect(body.data[0]).to.have.property('id');
  expect(body.data[0]).to.have.property('object', 'model');
  expect(body.data[0]).to.have.property('created');
  expect(body.data[0]).to.have.property('owned_by');

  // Should NOT have api_format (old behavior)
  expect(body.data[0]).to.not.have.property('api_format');
}
