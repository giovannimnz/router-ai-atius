# Sample env file for the router-ai-atius Podman stack.
# Copy to .env and fill in real values. NEVER commit .env.

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=newapi

# Redis
REDIS_PASSWORD=change-me

# Session secret (must match the new-api Go binary's SESSION_SECRET).
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-32-byte-hex

# Optional: override the SQL DSN (defaults to the postgres service above).
# SQL_DSN=postgresql://admin:change-me@db-newapi:5432/newapi?sslmode=disable
# REDIS_CONN_STRING=redis://:change-me@redis-newapi:6379
