FROM python:3.12-slim

WORKDIR /app

# Install FastAPI and uvicorn with httpx for async HTTP
RUN pip install --no-cache-dir \
    fastapi==0.115.0 \
    uvicorn[standard]==0.32.0 \
    httpx==0.27.2

# Copy middleware code
COPY model_detailed_fastapi.py /app/model_detailed_fastapi.py

# Expose port
EXPOSE 3001

# Run with uvicorn (4 workers for production)
CMD ["uvicorn", "model_detailed_fastapi:app", "--host", "0.0.0.0", "--port", "3001", "--workers", "4", "--log-level", "info"]
