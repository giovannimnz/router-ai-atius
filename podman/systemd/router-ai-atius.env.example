# Sample env file for the router-ai-atius Podman stack (rebrand v2.11).
# Copy to .env and fill in real values. NEVER commit .env.
# Generated into ~/.config/containers/systemd/router-ai-atius.env by
# scripts/podman-quadlets-install.sh.

# === PostgreSQL (router-ai-atius-db) ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=DBRouterAiAtius

# === Redis (router-ai-atius-redis) ===
REDIS_PASSWORD=change-me

# === Session secret (must match the router-ai-atius Go binary's SESSION_SECRET). ===
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-32-byte-hex

# === Optional: override the SQL DSN (defaults to the postgres service above). ===
# SQL_DSN=postgresql://admin:change-me@router-ai-atius-db:5432/DBRouterAiAtius?sslmode=disable
# REDIS_CONN_STRING=redis://:change-me@router-ai-atius-redis:6379
