# Quadlet state directories (not committed). Created on first run.
# See scripts/podman-quadlets-install.sh for the per-user install path.
# Note: the *.container unit files ARE committed (they're the templates).
# The .service files generated by `systemctl --user daemon-reload` are
# per-host state and live in a different directory (~/.config/containers/
# systemd/.service), not here.
