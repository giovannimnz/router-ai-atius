# router-ai-atius — environment file (rebrand v2.11.0)
# This file is sourced by docker compose / podman-compose.
# Do NOT commit real secrets to git.

# === Postgres (router-ai-atius-db) ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=DBRouterAiAtius

# === Redis (router-ai-atius-redis) ===
REDIS_PASSWORD=change-me-strong-password

# === Session secret (router-ai-atius Go binary) ===
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-32-byte-hex-string

# === Application ports (host) ===
# Apache reverse proxy fronts 443 and forwards to:
#   - router-ai-atius:        3030 → 3000
#   - router-ai-atius-model-detailed: 3300 → 3001

# === Optional: override the SQL DSN (defaults to the postgres service above) ===
# SQL_DSN=postgresql://admin:change-me@router-ai-atius-db:5432/DBRouterAiAtius?sslmode=disable
# REDIS_CONN_STRING=redis://:change-me@router-ai-atius-redis:6379

# === Node / debug ===
NODE_NAME=router-ai-atius-podman
TZ=America/Sao_Paulo
LANG=pt_BR.UTF-8
TRUST_PROXY=true
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# === upstream QuantumNous/new-api (rebrand) ===
# NOTE: see AGENTS.md Rule 5 — QuantumNous brand must NOT be removed.
UPSTREAM_REPO=QuantumNous/new-api
