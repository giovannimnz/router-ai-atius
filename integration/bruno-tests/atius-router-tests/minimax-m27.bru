meta {
  name: MiniMax M2.7
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/v1/chat/completions
  body: json
}

headers {
  Authorization: Bearer {{apiToken}}
}

body:json {
  {
    "model": "{{minimax27}}",
    "messages": [
      {
        "role": "user",
        "content": "Say hello."
      }
    ],
    "max_tokens": 20
  }
}

tests {
  const status = res.getStatus();
  expect(status).to.equal(200);
  const body = res.getBody();
  expect(body.choices.length).to.be.above(0);
  expect(body.model).to.contain("MiniMax");
}
